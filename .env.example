# Neon PostgreSQL — get both from your Neon project dashboard
# DATABASE_URL  → pooled connection (used by the app at runtime via pg adapter)
# DIRECT_URL    → direct connection (used by Prisma CLI for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.pooler.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"
